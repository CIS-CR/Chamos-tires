---
import { business, getPublicPhoneHref, getPublicSmsHref } from '../config/business';

const phoneHref = getPublicPhoneHref();
const smsHref = getPublicSmsHref();
---

<section class="hero section-reveal" data-reveal>
  <div class="hero-copy">
    <p class="eyebrow">Used Tires in Apex, NC</p>
    <h1>Affordable Used Tires in Apex, NC</h1>
    <p class="hero-text">Looking for affordable used tires near you? Chamos Tire Co helps drivers in Apex and nearby Triangle communities find inspected used tires for cars, SUVs, trucks, and work vehicles.</p>
    <div class="hero-actions" aria-label="Primary tire request actions">
      <a class="button button-primary" href="#request">Find Your Tire</a>
      <details class="contact-menu">
        <summary class="button button-secondary">Call or Text Us</summary>
        <div class="contact-menu-panel">
          <a href={phoneHref}>Call {business.phone}</a>
          <a href={smsHref}>Text {business.phone}</a>
        </div>
      </details>
    </div>
    <p class="hero-note">Contact us to check current inventory and schedule a visit.</p>
  </div>
  <figure class="hero-media">
    <div class="hero-media-frame">
      <img
        src="/images/chamos-tires-hero-banner.jpg"
        width="1200"
        height="900"
        alt="Used tires for cars, SUVs, and trucks"
        decoding="async"
        fetchpriority="high"
      />
    </div>
    <figcaption>Chamos Tire Co availability requests for Apex and nearby Triangle communities.</figcaption>
  </figure>
</section>
