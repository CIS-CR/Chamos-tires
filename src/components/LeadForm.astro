---
import { business } from '../config/business';

const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY || '';
---

<form class="lead-form" id="lead-form" method="post" action="/api/leads" novalidate>
  <fieldset class="form-section">
    <legend>Contact information</legend>
    <div class="form-grid">
      <div class="field"><label for="customerName">Customer name</label><input id="customerName" name="customerName" autocomplete="name" maxlength="120" required aria-describedby="customerName-error form-status" /><p class="field-error" id="customerName-error"></p></div>
      <div class="field"><label for="phone">Phone number</label><input id="phone" name="phone" type="tel" autocomplete="tel" maxlength="32" aria-describedby="phone-error form-status" /><p class="field-error" id="phone-error"></p></div>
      <div class="field"><label for="email">Email address</label><input id="email" name="email" type="email" autocomplete="email" maxlength="254" aria-describedby="email-error form-status" /><p class="field-error" id="email-error"></p></div>
    </div>
  </fieldset>
  <fieldset class="form-section">
    <legend>Vehicle information</legend>
    <div class="form-grid">
      <div class="field"><label for="vehicleYear">Vehicle year</label><input id="vehicleYear" name="vehicleYear" inputmode="numeric" autocomplete="off" maxlength="12" required aria-describedby="vehicleYear-error form-status" /><p class="field-error" id="vehicleYear-error"></p></div>
      <div class="field"><label for="vehicleMake">Vehicle make</label><input id="vehicleMake" name="vehicleMake" autocomplete="off" maxlength="80" required aria-describedby="vehicleMake-error form-status" /><p class="field-error" id="vehicleMake-error"></p></div>
      <div class="field"><label for="vehicleModel">Vehicle model</label><input id="vehicleModel" name="vehicleModel" autocomplete="off" maxlength="80" required aria-describedby="vehicleModel-error form-status" /><p class="field-error" id="vehicleModel-error"></p></div>
    </div>
  </fieldset>
  <fieldset class="form-section">
    <legend>Tire request</legend>
    <div class="form-grid">
      <div class="field"><label for="tireSize">Tire size</label><input id="tireSize" name="tireSize" placeholder="Example: 225/65R17" autocomplete="off" maxlength="40" required aria-describedby="tireSizeHelp tireSize-error form-status" /><p class="field-help" id="tireSizeHelp">You can find this on the tire sidewall.</p><p class="field-error" id="tireSize-error"></p></div>
      <div class="field"><label for="tiresNeeded">Number of tires needed</label><select id="tiresNeeded" name="tiresNeeded" required aria-describedby="tiresNeeded-error form-status"><option value="">Select</option><option value="1">1 tire</option><option value="2">2 tires</option><option value="3">3 tires</option><option value="4">4 tires</option></select><p class="field-error" id="tiresNeeded-error"></p></div>
    </div>
  </fieldset>
  <fieldset class="form-section">
    <legend>Contact and visit preferences</legend>
    <div class="form-grid">
      <div class="field"><label for="preferredContactMethod">Preferred contact method</label><select id="preferredContactMethod" name="preferredContactMethod" required aria-describedby="preferredContactMethod-error form-status"><option value="">Select</option>{business.preferredContactMethods.map((method) => <option value={method.value}>{method.label}</option>)}</select><p class="field-error" id="preferredContactMethod-error"></p></div>
      <div class="field"><label for="preferredVisitDate">Preferred visit date</label><input id="preferredVisitDate" name="preferredVisitDate" type="date" aria-describedby="form-status" /></div>
    </div>
  </fieldset>
  <fieldset class="form-section">
    <legend>Additional notes and consent</legend>
    <div class="field"><label for="additionalNotes">Additional notes</label><textarea id="additionalNotes" name="additionalNotes" rows="4" maxlength="1200" placeholder="Share anything helpful, such as brand preference, urgency, or tire condition."></textarea></div>
  </fieldset>
  <input type="hidden" name="leadSource" value="chamos-tires-landing" />
  <input type="hidden" name="turnstileToken" id="turnstileToken" value="" />
  {turnstileSiteKey && <div class="turnstile-placeholder" data-sitekey={turnstileSiteKey}>Turnstile will render here when enabled.</div>}
  <label class="consent" for="consentToContact"><input id="consentToContact" name="consentToContact" type="checkbox" required />I agree that Chamos Tire Co may contact me about tire availability, pricing, and next steps.</label>
  <p class="form-note">Submitting this form does not reserve a tire or confirm an appointment. Chamos Tire Co will contact you after checking current inventory.</p>
  <p class="field-error" id="consentToContact-error"></p>
  <button class="button button-primary submit-button" type="submit">Submit Tire Request</button>
  <p class="form-status" id="form-status" role="status" aria-live="polite"></p>
</form>

<script>
  import { trackEvent } from '../lib/analytics/ga';

  const form = document.querySelector<HTMLFormElement>('#lead-form');
  const status = document.querySelector<HTMLElement>('#form-status');
  let hasTrackedFormStart = false;

  form?.addEventListener('focusin', () => {
    if (hasTrackedFormStart) return;
    hasTrackedFormStart = true;
    trackEvent('form_start', {
      form_name: 'tire_request',
      service: 'used_tire_request',
    });
  });

  form?.addEventListener('submit', async (event) => {
    event.preventDefault();
    if (!status) return;

    const formData = new FormData(form);
    const requiredFields = ['customerName', 'vehicleYear', 'vehicleMake', 'vehicleModel', 'tireSize', 'tiresNeeded', 'preferredContactMethod'];
    const missing = requiredFields.filter((field) => !String(formData.get(field) || '').trim());
    const preferredContactMethod = String(formData.get('preferredContactMethod') || '');
    const phone = String(formData.get('phone') || '').trim();
    const email = String(formData.get('email') || '').trim();
    const submitButton = form.querySelector<HTMLButtonElement>('.submit-button');
    form.querySelectorAll('.field-error').forEach((error) => { error.textContent = ''; });
    form.querySelectorAll('[aria-invalid="true"]').forEach((field) => field.removeAttribute('aria-invalid'));

    if (preferredContactMethod === 'phone_call' && !phone) missing.push('phone');
    if (preferredContactMethod === 'text_message' && !phone) missing.push('phone');
    if (preferredContactMethod === 'email' && !email) missing.push('email');
    if (email && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      missing.push('email');
    }

    if (missing.length || formData.get('consentToContact') !== 'on') {
      missing.forEach((field) => {
        const input = form.querySelector<HTMLElement>(`[name="${field}"]`);
        const error = document.getElementById(`${field}-error`);
        input?.setAttribute('aria-invalid', 'true');
        if (error && field === 'phone' && preferredContactMethod === 'phone_call') {
          error.textContent = 'Please enter a phone number so we can call you.';
        } else if (error && field === 'phone' && preferredContactMethod === 'text_message') {
          error.textContent = 'Please enter a phone number so we can text you.';
        } else if (error && field === 'email' && preferredContactMethod === 'email') {
          error.textContent = 'Please enter an email address so we can contact you by email.';
        } else if (error && field === 'email') {
          error.textContent = 'Email address is not valid.';
        } else if (error) {
          error.textContent = 'This field is required.';
        }
      });
      if (formData.get('consentToContact') !== 'on') {
        const error = document.getElementById('consentToContact-error');
        if (error) error.textContent = 'This field is required.';
      }
      status.textContent = 'Please complete the required fields and consent checkbox.';
      status.dataset.state = 'error';
      const firstInvalid = form.querySelector<HTMLElement>('[aria-invalid="true"], #consentToContact');
      firstInvalid?.scrollIntoView({ behavior: 'smooth', block: 'center' });
      firstInvalid?.focus();
      return;
    }

    const payload: Record<string, string> = {};
    formData.forEach((value, key) => {
      payload[key] = String(value);
    });
    payload.consentToContact = String(formData.get('consentToContact') === 'on');
    status.textContent = 'Sending your request...';
    status.dataset.state = 'pending';
    form.dataset.state = 'loading';
    if (submitButton) {
      submitButton.disabled = true;
      submitButton.textContent = 'Sending your request...';
    }

    try {
      const response = await fetch('/api/leads', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      const result = (await response.json()) as { success?: boolean; error?: string };
      if (!response.ok || !result.success) {
        status.textContent = result.error || 'Unable to send your request. Please try again.';
        status.dataset.state = 'error';
        form.dataset.state = 'error';
        return;
      }
      form.reset();
      status.textContent = 'Request received. Chamos Tire Co will follow up with availability and next steps.';
      status.dataset.state = 'success';
      form.dataset.state = 'success';
      trackEvent('generate_lead', {
        form_name: 'tire_request',
        service: 'used_tire_request',
      });
    } catch {
      status.textContent = 'Unable to send your request right now. Please try again.';
      status.dataset.state = 'error';
      form.dataset.state = 'error';
    } finally {
      if (submitButton) {
        submitButton.disabled = false;
        submitButton.textContent = 'Submit Tire Request';
      }
    }
  });
</script>
