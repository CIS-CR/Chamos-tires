<section class="tire-helper" aria-labelledby="tire-helper-title" data-reveal>
  <div class="tire-visual" aria-hidden="true">
    <div class="tire-ring">
      <span>225 / 65 R17</span>
    </div>
  </div>
  <div class="tire-helper-content">
    <p class="eyebrow">Tire Size Helper</p>
    <h3 id="tire-helper-title">225 / 65 R17</h3>
    <div class="measure-grid">
      <button type="button" class="measure-chip" aria-expanded="false" aria-controls="measure-width" data-disclosure>225</button>
      <p id="measure-width" hidden>Section width</p>
      <button type="button" class="measure-chip" aria-expanded="false" aria-controls="measure-profile" data-disclosure>65</button>
      <p id="measure-profile" hidden>Aspect ratio</p>
      <button type="button" class="measure-chip" aria-expanded="false" aria-controls="measure-wheel" data-disclosure>R17</button>
      <p id="measure-wheel" hidden>Wheel diameter</p>
    </div>
    <a class="button button-secondary" href="#tireSize" data-focus-tire-size>Find Your Tire</a>
  </div>
</section>
