---
import LocationMap from './LocationMap.astro';
import Nap from './Nap.astro';
import { serviceAreaChips } from '../content/home';
---

<section class="section muted service-area-section" id="service-area" data-reveal>
  <div class="service-area-copy">
    <p class="eyebrow">Service Area</p>
    <h2>Used Tires Near Apex and Surrounding Communities</h2>
    <p>Chamos Tire Co is focused on tire availability in Apex and nearby Triangle communities, including Holly Springs, Fuquay-Varina, Cary, Raleigh, and surrounding areas in North Carolina.</p>
    <p>Chamos Tire Co serves customers from Apex and nearby Triangle communities from one storage location in Apex. Tire availability must be confirmed and visits must be scheduled before arrival.</p>
    <Nap compact />
    <div class="local-links" aria-label="Future local landing page plan">
      <span>Future local pages planned:</span>
      {serviceAreaChips.map((chip) => <span>{chip}</span>)}
    </div>
  </div>
  <LocationMap />
</section>
