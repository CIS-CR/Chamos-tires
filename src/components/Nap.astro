---
import { business, businessLocationLabel, getPublicEmailHref, getPublicPhoneHref } from '../config/business';

interface Props {
  compact?: boolean;
}

const { compact = false } = Astro.props;
const phoneHref = getPublicPhoneHref();
const emailHref = getPublicEmailHref();
const hasFullAddress = Boolean(business.streetAddress);
---

<address class:list={['nap', compact && 'nap-compact']}>
  <strong>{business.publicName}</strong>
  {hasFullAddress ? (
    <span>{business.streetAddress}, {business.city}, {business.state} {business.zipCode}</span>
  ) : (
    <span>{businessLocationLabel} service area. Public street address pending confirmation.</span>
  )}
  <span>{business.operatingHoursText}</span>
  <a href={phoneHref}>{business.phone}</a>
  <a href={emailHref}>{business.email}</a>
</address>
