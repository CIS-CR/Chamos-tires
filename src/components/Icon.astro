}

const { name, class: className = '' } = Astro.props;
const icons = {
  sedan: 'M6 25h4l3-7h22l5 7h4M11 25h30M12 25v6m28-6v6M14 31a3 3 0 1 0 0 6 3 3 0 0 0 0-6Zm24 0a3 3 0 1 0 0 6 3 3 0 0 0 0-6ZM15 18l4-6h13l5 6',
