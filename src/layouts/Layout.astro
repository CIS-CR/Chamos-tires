---
import SEO from '../components/SEO.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  image?: string;
  imageAlt?: string;
  noindex?: boolean;
  pageType?: 'website' | 'article';
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
  locale?: string;
}

const {
  title = 'Used Tires in Apex, NC | Chamos Tire Co',
  description = 'Find affordable, inspected used tires for cars, SUVs, and trucks in Apex, NC. Request tire availability from Chamos Tire Co today.',
  canonical = Astro.url.pathname,
  image,
  imageAlt,
  noindex,
  pageType,
  structuredData,
  locale,
} = Astro.props;
---

<!doctype html>
<html lang="en-US">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <SEO
      title={title}
      description={description}
      canonical={canonical}
      image={image}
      imageAlt={imageAlt}
      noindex={noindex}
      pageType={pageType}
      structuredData={structuredData}
      locale={locale}
    />
  </head>
  <body>
    <slot />
  </body>
</html>
