---
import FAQAccordion from '../components/FAQAccordion.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import HowItWorksTimeline from '../components/HowItWorksTimeline.astro';
import Nap from '../components/Nap.astro';
import LeadForm from '../components/LeadForm.astro';
import Layout from '../layouts/Layout.astro';
import PaymentMethods from '../components/PaymentMethods.astro';
import ServiceAreaSection from '../components/ServiceAreaSection.astro';
import ServicesSection from '../components/ServicesSection.astro';
import SiteInteractions from '../components/SiteInteractions.astro';
import StickyMobileCTA from '../components/StickyMobileCTA.astro';
import TireSizeHelper from '../components/TireSizeHelper.astro';
import TrustStrip from '../components/TrustStrip.astro';
import { business } from '../config/business';
import { createTireShopJsonLd } from '../lib/seo/structuredData';

const title = 'Used Tires in Apex, NC | Chamos Tire Co';
const description = 'Find affordable, inspected used tires for cars, SUVs, and trucks in Apex, NC. Request tire availability from Chamos Tire Co today.';
const socialImage = business.defaultSocialImage;
const canonicalUrl = new URL('/', business.mainDomain).toString();
const socialImageUrl = new URL(socialImage, business.mainDomain).toString();
const structuredData = createTireShopJsonLd(canonicalUrl, socialImageUrl);
---

<Layout
  title={title}
  description={description}
  canonical="/"
  image={socialImage}
  imageAlt="Chamos Tire Co used tire availability in Apex, North Carolina"
  structuredData={structuredData}
>
  <Header />

  <main>
    <Hero />
    <TrustStrip />
    <ServicesSection />

    <section class="section muted" id="why-choose-us">
      <p class="eyebrow">Why Choose Us</p>
      <h2>Why Apex Drivers Choose Chamos Tire Co</h2>
      <div class="split">
        <p>Chamos Tire Co provides a clear and personalized process for checking used tire availability. Customers can contact the team with their tire size or vehicle information, and current inventory is reviewed manually before available options, pricing, and appointment details are confirmed.</p>
        <ul class="check-list">
          <li>Tires visually inspected before being offered for sale.</li>
          <li>Affordable options for different budgets.</li>
          <li>Personalized assistance with size and vehicle information.</li>
          <li>Different sizes and brands, depending on inventory.</li>
          <li>Honest and transparent local service.</li>
          <li>Visits scheduled individually after tire availability is confirmed.</li>
        </ul>
      </div>
    </section>

    <HowItWorksTimeline />
    <ServiceAreaSection />

    <section class="section request-section" id="request">
      <div>
        <p class="eyebrow">Check Tire Availability</p>
        <h2>Find Your Tire</h2>
        <p>Send your tire size or vehicle information to request current availability. Chamos Tire Co will check inventory manually and contact you with available options, pricing, and appointment details.</p>
        <TireSizeHelper />
        <PaymentMethods compact />
      </div>
      <LeadForm />
    </section>

    <FAQAccordion />
  </main>

  <footer class="site-footer">
    <div class="footer-brand">
      <img class="footer-logo" src={business.logoPath} width="44" height="44" alt="" loading="lazy" decoding="async" />
      <span>{business.publicName}</span>
    </div>
    <Nap />
    <PaymentMethods compact />
    <p>Contact us to check inventory and schedule your visit.</p>
    <a href="/privacy">Privacy</a>
  </footer>
  <StickyMobileCTA />
  <SiteInteractions />
</Layout>
